NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1
NEXT_PUBLIC_FIREBASE_CALLABLE_TRANSPORT_MODE=proxy-first

# Fastify API (Turso-backed)
# Local dev: http://localhost:3001
# Production (your plan): https://api.thinkmart.in
NEXT_PUBLIC_API_URL=https://api.thinkmart.in

# Frontend feature flags (must mirror backend rollout/capabilities)
NEXT_PUBLIC_FF_READ_API_ENABLED=true
NEXT_PUBLIC_FF_WRITE_API_ENABLED=true
NEXT_PUBLIC_FF_REALTIME_ENABLED=false
NEXT_PUBLIC_FF_UPLOAD_R2_ENABLED=false

# Public asset URL (Cloudflare R2 public domain / CDN)
NEXT_PUBLIC_R2_PUBLIC_URL=
NEXT_PUBLIC_R2_PUBLIC_DOMAIN=

# Typesense (public search key only)
NEXT_PUBLIC_TYPESENSE_HOST=
NEXT_PUBLIC_TYPESENSE_PORT=443
NEXT_PUBLIC_TYPESENSE_PROTOCOL=https
NEXT_PUBLIC_TYPESENSE_SEARCH_API_KEY=

# NOTE:
# Turso / Fastify server secrets are NOT added here because the API runs from /server.
# Create server/.env (or set Railway env vars) with:
# TURSO_DATABASE_URL=libsql://...
# TURSO_AUTH_TOKEN=...
# CORS_ALLOWED_ORIGINS=http://localhost:3000
# FIREBASE_PROJECT_ID=...
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json (local only, optional if using ADC)
