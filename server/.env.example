# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=debug

# TursoDB
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# Redis
REDIS_URL=redis://localhost:6379

# Firebase Admin (for token verification)
# Option 1: Path to service account JSON
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# Option 2: Provide project ID (cloud environments with default credentials)
# FIREBASE_PROJECT_ID=your_project_id

# Cloudflare R2
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=thinkmart-assets
R2_PUBLIC_URL=https://cdn.thinkmart.com

# Typesense
TYPESENSE_HOST=your_typesense_host
TYPESENSE_API_KEY=your_typesense_api_key

# CORS
# Include frontend production domain(s) + local dev
CORS_ALLOWED_ORIGINS=https://thinkmart.in,https://www.thinkmart.in,http://localhost:3000,http://localhost:3001

# Feature Flags (defaults for development)
FF_READ_API_ENABLED=true
FF_WRITE_API_ENABLED=true
FF_REALTIME_ENABLED=false
FF_UPLOAD_R2_ENABLED=false
FF_JOBS_ENABLED=false
