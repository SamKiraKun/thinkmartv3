{
    "name": "thinkmart-api",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start:api": "node dist/index.js",
        "start:worker": "node dist/jobs/worker.js",
        "lint": "eslint src/",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "db:migrate": "tsx src/db/migrate.ts",
        "db:migrate:status": "tsx src/db/migrate.ts --status"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.995.0",
        "@aws-sdk/s3-request-presigner": "^3.995.0",
        "@fastify/cors": "^9.0.1",
        "@fastify/rate-limit": "^9.1.0",
        "@fastify/websocket": "^10.0.1",
        "@libsql/client": "^0.14.0",
        "bullmq": "^5.34.8",
        "dotenv": "^16.4.7",
        "fastify": "^4.29.1",
        "firebase-admin": "^13.0.2",
        "ioredis": "^5.4.2",
        "nanoid": "^5.1.2",
        "pino": "^9.6.0",
        "pino-pretty": "^13.0.0",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/node": "^22.13.5",
        "@typescript-eslint/eslint-plugin": "^8.24.1",
        "@typescript-eslint/parser": "^8.24.1",
        "cross-env": "^10.1.0",
        "eslint": "^9.20.0",
        "tsx": "^4.21.0",
        "typescript": "^5.7.3",
        "vitest": "^3.0.7"
    }
}
