{
  "name": "thinkmart-migration-scripts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "ETL scripts for migrating ThinkMart from Firestore to TursoDB",
  "scripts": {
    "export": "tsx export-firestore/export.ts",
    "transform": "tsx transform/transform.ts",
    "import": "tsx import-turso/import.ts",
    "validate": "tsx validate/validate.ts",
    "etl": "tsx export-firestore/export.ts && tsx transform/transform.ts && tsx import-turso/import.ts && tsx validate/validate.ts",
    "etl:dry-run": "tsx export-firestore/export.ts --dry-run"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "@libsql/client": "^0.14.0",
    "zod": "^3.24.2",
    "dotenv": "^16.4.7",
    "nanoid": "^5.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
